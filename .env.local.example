# Supabase project settings — find these in Supabase dashboard > Project Settings > API

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in the browser bundle (RLS restricts it to read-only here)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET service role key — bypasses RLS entirely.
# Server-only. NEVER prefix with NEXT_PUBLIC_, never import into a client component.
SUPABASE_SERVICE_ROLE_KEY=
